# Variáveis de Ambiente - Queto System

# ════════════════════════════════════════════════════════════════════════
# API & SERVICES
# ════════════════════════════════════════════════════════════════════════

# Groq API Key (obter em https://console.groq.com)
API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentence Transformers Model
# Opções:
# - distiluse-base-multilingual-case-sensitive-v2 (padrão)
# - paraphrase-multilingual-MiniLM-L12-v2 (menor)
# - paraphrase-multilingual-mpnet-base-v2 (maior)
SENTENCE_TRANSFORMER_MODEL=distiluse-base-multilingual-case-sensitive-v2

# ════════════════════════════════════════════════════════════════════════
# DATABASE
# ════════════════════════════════════════════════════════════════════════

# SQLite (desenvolvimento)
DATABASE_URL=sqlite:///./queto.db

# PostgreSQL (produção) - descomente para usar
# DATABASE_URL=postgresql://user:password@localhost:5432/queto_db

# Redis (cache e rate limiting)
REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════════════════
# SERVER
# ════════════════════════════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8000

# development / production
ENVIRONMENT=development

# True for desenvolvimento, False para produção
DEBUG=True

# Workers para Uvicorn (produção)
WORKERS=4

# ════════════════════════════════════════════════════════════════════════
# C2M CONFIGURATION
# ════════════════════════════════════════════════════════════════════════

# Número de simulações Monte Carlo
MONTE_CARLO_SIMULATIONS=50000

# Thresholds de decisão
CRISIS_DECISION_THRESHOLD=0.4
CRISIS_PROBABILITY_THRESHOLD=0.5

# Weights para cálculo de probabilidade (devem somar 1.0)
WEIGHT_SENTIMENT=0.34
WEIGHT_MATURITY=0.255
WEIGHT_PLAN=0.17
WEIGHT_HISTORY=0.085
WEIGHT_CONFORMITY=0.15

# ════════════════════════════════════════════════════════════════════════
# SECURITY
# ════════════════════════════════════════════════════════════════════════

# CORS origins
CORS_ORIGINS=["*"]

# Allowed hosts
ALLOWED_HOSTS=["localhost", "127.0.0.1", "0.0.0.0"]

# Secret key para JWT (gere com: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# Token expiration (em minutos)
TOKEN_EXPIRATION=60

# ════════════════════════════════════════════════════════════════════════
# AUDIO PROCESSING
# ════════════════════════════════════════════════════════════════════════

# Diretório temporário para arquivos de áudio
AUDIO_TEMP_DIR=./temp/audio

# Tamanho máximo de arquivo de áudio (em bytes)
MAX_AUDIO_FILE_SIZE=104857600  # 100MB

# Idioma padrão para transcrição
AUDIO_LANGUAGE=pt

# Whisper Model (via Groq)
WHISPER_MODEL=whisper-large-v3-turbo

# ════════════════════════════════════════════════════════════════════════
# VECTOR SEARCH
# ════════════════════════════════════════════════════════════════════════

# Similarity threshold mínimo para vector search
VECTOR_SIMILARITY_THRESHOLD=0.3

# Número de documentos para calcular conformidade
VECTOR_TOP_K=5

# Cache de embeddings (em número de documentos)
VECTOR_CACHE_SIZE=1000

# ════════════════════════════════════════════════════════════════════════
# RLHF & LEARNING
# ════════════════════════════════════════════════════════════════════════

# Learning rate para ajuste de weights
LEARNING_RATE=0.001

# Número mínimo de feedbacks para ajustar weights
MIN_FEEDBACKS_FOR_WEIGHT_UPDATE=10

# Intervalo de atualização de weights (em horas)
WEIGHT_UPDATE_INTERVAL=24

# ════════════════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Arquivo de log
LOG_FILE=./logs/queto.log

# Tamanho máximo do arquivo de log (em MB)
LOG_MAX_SIZE=10

# Número de backups de log para manter
LOG_BACKUP_COUNT=5

# ════════════════════════════════════════════════════════════════════════
# LLM (EXPLICAÇÕES)
# ════════════════════════════════════════════════════════════════════════

# Model para explicações narrativas
EXPLANATION_MODEL=llama-3.2-90b-text-preview

# Temperature para geração (0.0 = determinístico, 1.0 = criativo)
LLM_TEMPERATURE=0.3

# Max tokens para explicação
LLM_MAX_TOKENS=500

# ════════════════════════════════════════════════════════════════════════
# MONITORING & METRICS
# ════════════════════════════════════════════════════════════════════════

# Prometheus metrics endpoint
PROMETHEUS_ENABLED=False

# Health check interval (em segundos)
HEALTH_CHECK_INTERVAL=300

# ════════════════════════════════════════════════════════════════════════
# EMAIL (optional)
# ════════════════════════════════════════════════════════════════════════

# SMTP Server
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email para alertas
ALERT_EMAIL=security@company.com

# ════════════════════════════════════════════════════════════════════════
# EXTERNAL INTEGRATIONS
# ════════════════════════════════════════════════════════════════════════

# Slack webhook para alertas
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# DataDog API key (monitoramento)
DATADOG_API_KEY=

# ════════════════════════════════════════════════════════════════════════
# DATA & PRIVACY (LGPD)
# ════════════════════════════════════════════════════════════════════════

# Retenção de dados brutos de áudio (em dias)
AUDIO_RETENTION_DAYS=30

# Retenção de relatórios (em dias)
REPORTS_RETENTION_DAYS=365

# Habilitar anonimização de PII
ANONYMIZE_PII=True

# ════════════════════════════════════════════════════════════════════════
# DEVELOPMENT ONLY
# ════════════════════════════════════════════════════════════════════════

# Mock mode (usa dados simulados em vez de chamadas reais)
MOCK_MODE=False

# Seed para reproducibilidade
RANDOM_SEED=42

# Verbose output
VERBOSE=False
